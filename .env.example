# Display name for your channel (shown to friends)
NODE_NAME=My Channel

# Your Tailscale IP — auto-detected if Tailscale is running, or set manually
# Run: tailscale ip -4
TAILSCALE_IP=100.xxx.xxx.x

# URL of the shared registry
REGISTRY_URL=https://fly.io/apps/friendchannel-registry

# Port to run on (default: 7777)
# PORT=7777
